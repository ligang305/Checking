<local:BaseWindows x:Class="BGUserControl.ToggleSwitchButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="LayoutRoot"
          Background="Transparent"
          Width="50" Height="30">
        <Border Name="fillRectangle" BorderBrush="#497274" CornerRadius="15"
                BorderThickness="2" Background="#808080" >
            <!--<Rectangle Name="fillRectangle" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       Fill="#808080"/>-->
        </Border>
        <Border Name="slideBorder"  Width="28" Height="28"  Margin="0" HorizontalAlignment="Left" BorderThickness="0">
            <Ellipse Stroke="#FFFFFF"
                       Fill="#FFFFFF"
                       StrokeThickness="2"
                       Width="28" Height="28" />

        </Border>
    </Grid>
    </local:BaseWindows>
