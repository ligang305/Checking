<local:DiyUserModule
            x:Class="BGUserControl.DiySafeCondition"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d">
    <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" BorderThickness="2"
            BorderBrush="#3F96E9" CornerRadius="6" Background="#F2F2F2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <DockPanel x:Name="dp" MouseLeftButtonDown="Dp_MouseLeftButtonDown" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" LastChildFill="True"
                       Background="{DynamicResource TitleBackGround}">
                <Label x:Name="lblTitle" Content="标题" HorizontalAlignment="Left" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" FontFamily="宋体" VerticalAlignment="Stretch"
                       HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Border BorderThickness="0" BorderBrush="{DynamicResource LnearBorderColor}" HorizontalAlignment="Right" VerticalAlignment="Stretch" PreviewMouseLeftButtonDown="Border_PreviewMouseLeftButtonDown"
                        Width="32" Background="#00FFFFFF">
                    <Canvas Style="{DynamicResource diyCloseCanvas}" HorizontalAlignment="Right" Margin="0,1,10,0" />
                </Border>
            </DockPanel>
            <Grid x:Name="ContentGrid" HorizontalAlignment="Stretch" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1">
                <Label x:Name="lblMainContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch"/>
            </Grid>
        </Grid>
    </Border>
   
</local:DiyUserModule>
