<UserControl x:Class="BGUserControl.DiyStopPressButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Width="100" Height="100" MouseDown="Border_MouseDown" MouseEnter="Border_MouseEnter" MouseLeave="Border_MouseLeave" BorderThickness="0">
        <Image x:Name="PressStop" Source="{Binding ImageBitmapSource}" HorizontalAlignment="Left" 
                                VerticalAlignment="Stretch"  Stretch="Fill" />
    </Border>
</UserControl>
