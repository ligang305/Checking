<UserControl x:Class="BGUserControl.UserNameCtl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="122" d:DesignWidth="150">
    <Grid>
        <Label Name="lbl_UserName" Content="{Binding FastCheckEntityModel.userName}" Foreground="#96FFFE"  FontSize="{Binding fontSizeModel.normal}"  HorizontalAlignment="Left" Margin="15,0,0,0"
                               VerticalAlignment="Stretch" VerticalContentAlignment="Center" FontWeight="UltraBold"  HorizontalContentAlignment="Center" Grid.Column="1"/>

    </Grid>
</UserControl>
