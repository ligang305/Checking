<UserControl x:Class="BGUserControl.RayThumbCtl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="254">
    <Grid>
        <Border x:Name="ImageCanvas" BorderThickness="0"  >
            <Border.Child>
                <Image x:Name="SmallHandImage" Source="{Binding SmallRayImage.ImageBitmapSource}" Stretch="Uniform"
                                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"   />
            </Border.Child>
        </Border>
        <Canvas x:Name="RayCanvas"   HorizontalAlignment="Left" VerticalAlignment="Top"  Width="254" Height="200" Panel.ZIndex="1000" />
    </Grid>
</UserControl>
