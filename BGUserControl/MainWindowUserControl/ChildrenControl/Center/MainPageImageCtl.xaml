<UserControl x:Class="BGUserControl.MainPageImageCtl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d">
    <Grid>
        <Image x:Name="MainImage" HorizontalAlignment="Stretch" Source="{Binding MainVisibly.ImageBitmapSource,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                       VerticalAlignment="Stretch"   Stretch="Fill" Height="500" />
        <!--"Source="../Image/PassageCar.png"-->
        <Image x:Name="CarImage" Source="{Binding CarVisibly.ImageBitmapSource,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Right" 
                                       VerticalAlignment="Center"  Width="300" Height="200" Panel.ZIndex="900" />
        <Image x:Name="AcclaterImage" Source="{Binding AccleatorVisibly.ImageBitmapSource,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="-360,0,0,5" Width="1000" Height="590"  Stretch="UniformToFill"  Panel.ZIndex="1000"/>
    </Grid>
</UserControl>
