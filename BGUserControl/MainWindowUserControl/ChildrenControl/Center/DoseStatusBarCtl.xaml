<UserControl x:Class="BGUserControl.DoseStatusBarCtl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" CornerRadius="4" BorderThickness="0"
        VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
        Background="{StaticResource MainPageParamaterBG}">
            <Label x:Name="Title" VerticalAlignment="Stretch" VerticalContentAlignment="Center"
           HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"
           Foreground="White"  FontSize="16"
           Content="{Binding ControlNamePanel,Mode=TwoWay}"
           Grid.Row ="0" Width="250" Height="38" />
        </Border>
        <!-- 右侧温度计量图 -->
        <Border  BorderThickness="0" BorderBrush="#014087" Grid.Row="1">
            <ScrollViewer x:Name="svParamaterGrid" VerticalScrollBarVisibility="Auto" VerticalAlignment="Stretch" Template="{StaticResource MyScrollViewer}" >
                <Grid x:Name="paramaterGrid" ScrollViewer.CanContentScroll="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
