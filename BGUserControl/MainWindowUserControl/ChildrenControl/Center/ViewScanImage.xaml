<UserControl x:Class="BGUserControl.ViewScanImage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" >
    <GroupBox >
        <GroupBox.Header>
            <local:DiyStatusLabel x:Name="lbl_DetectorConnection" 
                            LabelText="{Binding LabelText,Mode=TwoWay}"
                            LabmForecolor="{Binding LabmForecolor,Mode=TwoWay}"
                            HorizontalAlignment="Left" Margin="5,2,0,0"
                            VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                            FontWeight="UltraBold"  HorizontalContentAlignment="Center"/>
        </GroupBox.Header>
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <local:ScanImage x:Name="RollImage" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Visibility="{Binding IsTestMode}" >
                <Button Content="扫描" Command="{Binding ScanCommand}"  Width="80" Height="30"  Margin="5"/>
                <Button Content="停止扫描" Command="{Binding DisScanCommand}"  Width="80" Height="30"  Margin="5"/>
                <Button Content="校正" Command="{Binding CorrectCommand}" Width="80" Height="30"  Margin="5"/>
                <Button Content="保存" Command="{Binding SavePngCommand}" Width="80" Height="30"  Margin="5"/>
            </StackPanel>
        </Grid>
    </GroupBox>
 
</UserControl>
