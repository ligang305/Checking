<controls:MetroWindow x:Class="CMW.SystemMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:command="http://www.galasoft.ch/mvvmlight"
        mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="800" 
        BorderThickness="1" BorderBrush="{DynamicResource AccentColorBrush}" 
        UseNoneWindowStyle="True"
        WindowStyle="None"
        IsWindowDraggable="False" 
        ResizeMode="NoResize" Background="{StaticResource newBlue}"
        WindowTransitionsEnabled="False"  ShowInTaskbar="False"
        InputMethod.IsInputMethodEnabled="False" 
        KeyDown="SystemMenuWindow_OnKeyDown" 
        PreviewKeyDown="SystemMenuWindow_OnPreviewKeyDown"
        PreviewKeyUp="SystemMenuWindow_OnPreviewKeyUp"
        WindowStartupLocation="Manual"
        Title="SystemMenuWindow" 
        DataContext="{Binding SystemMenuWindowVm, Source={StaticResource Locator}}">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="KeyDown">
            <command:EventToCommand Command="{Binding KeyDownCommand}" PassEventArgsToCommand="True"></command:EventToCommand>
        </i:EventTrigger>
        <i:EventTrigger EventName="KeyUp">
            <command:EventToCommand Command="{Binding KeyUpCommand}" PassEventArgsToCommand="True"></command:EventToCommand>
        </i:EventTrigger>
        <i:EventTrigger EventName="PreviewKeyDown">
            <command:EventToCommand Command="{Binding PreviewKeyDownCommand}" PassEventArgsToCommand="True"></command:EventToCommand>
        </i:EventTrigger>
        <i:EventTrigger EventName="PreviewKeyUp">
            <command:EventToCommand Command="{Binding PreviewKeyUpCommand}" PassEventArgsToCommand="True"></command:EventToCommand>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Name="TitleBarGrid" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <!--<RowDefinition/>-->
            </Grid.RowDefinitions>

            <Grid Grid.Column="2" Grid.Row="0" Name="SystemMenuGrid" HorizontalAlignment="Right">
                <Button Name="CloseButton" Click="CloseButton_OnClick" 
                         VerticalAlignment="Top" IsTabStop="False">
                    <Button.Content>
                        <Grid >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition  Width="Auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="[F3]" VerticalAlignment="Center" FontSize="{StaticResource SystemMenuButtonSize}"></Label>
                            <Image Grid.Column="1" Source="../../Icons/Close.png" Width="{StaticResource SystemMenuButtonSize}" ></Image>
                        </Grid>
                    </Button.Content>
                </Button>
            </Grid>
            
            <DockPanel Name="SecondRowDockPanel" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" LastChildFill="True">
                <Grid Name="PageTitleGrid" DockPanel.Dock="Left" Margin="{StaticResource PageContentMargin}">
                    <TextBlock Name="PageTitleTextBlock" HorizontalAlignment="{Binding PageTitleTextBlockAlignment}" VerticalAlignment="Center"
                               FontSize="{StaticResource DialogTitleFontSize}" Text="{Binding ElementName=PageFrame,Path=Content.Title}"></TextBlock>
                </Grid>
            </DockPanel>
        </Grid>
        
        <Grid Name="FrameGrid" Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Frame Grid.Column="0" Name="MenuFrame" NavigationUIVisibility="Hidden" IsTabStop="False"></Frame>
            <Frame Grid.Column="1" Name="PageFrame" Source="View/Pages/SystemMenu/SystemMenuPage.xaml"
                       NavigationUIVisibility="Hidden" IsTabStop="False">
            </Frame>
        </Grid>
    </Grid>
</controls:MetroWindow>