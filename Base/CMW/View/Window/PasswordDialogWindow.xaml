<mah:MetroWindow x:Class="CMW.PasswordDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
                 xmlns:command="http://www.galasoft.ch/mvvmlight"
                 xmlns:system="clr-namespace:System;assembly=mscorlib"
                 xmlns:extensions="clr-namespace:CMW.Common.Utilities;assembly=CMW.Common.Utilities"
                 ResizeMode="NoResize" SizeToContent="WidthAndHeight"  WindowStartupLocation="CenterScreen"
                 ShowInTaskbar="False" Title="{Binding Caption}" ShowCloseButton="False" 
                 Background="{StaticResource TabItem.Static.Background}" 
                 NonActiveWindowTitleBrush="{StaticResource newBlue}" 
                 NonActiveBorderBrush="{StaticResource newBlue}"
                 WindowTitleBrush="{StaticResource newBlue}"
                 BorderBrush="{StaticResource newBlue}">
    <Window.Resources>
        <system:Double x:Key="MinButtonHeight">35</system:Double>
        <system:Double x:Key="MinButtonWidth">200</system:Double>
    </Window.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="PreviewKeyDown">
            <command:EventToCommand Command="{Binding PreviewKeyDownCommand}" PassEventArgsToCommand="True">
            </command:EventToCommand>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Border BorderThickness="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <DockPanel LastChildFill="True">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <DockPanel LastChildFill="True">
                    <UniformGrid DockPanel.Dock="Bottom" VerticalAlignment="Center" HorizontalAlignment="Stretch" Rows="1">
                        <Border Margin="5,0" MinWidth="{StaticResource MinButtonWidth}" MinHeight="{StaticResource MinButtonHeight}" 
                                Name="OkButton" Visibility="{Binding ShowOk}" Style="{StaticResource diyBtnCarHand}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseDown">
                                    <command:EventToCommand Command="{Binding OkCommand}" PassEventArgsToCommand="True">
                                    </command:EventToCommand>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <Border.Child>
                                <Grid HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock TextWrapping="Wrap" Text="{Binding OK}" Foreground="{StaticResource PopupBackGrand}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Margin="5,0,0,0" Text="[F1]" Foreground="{StaticResource PopupBackGrand}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border.Child>
                        </Border>
                        <Border Margin="5,0" MinWidth="{StaticResource MinButtonWidth}" MinHeight="{StaticResource MinButtonHeight}" 
                    Name="CancelButton" Visibility="{Binding ShowCancel}" Style="{StaticResource diyBtnCarHand}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseDown">
                                    <command:EventToCommand Command="{Binding CancelCommand}" PassEventArgsToCommand="True">
                                    </command:EventToCommand>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <Border.Child>
                                <Grid HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock TextWrapping="Wrap" Text="{Binding Cancel}" Foreground="{StaticResource PopupBackGrand}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
                                    <TextBlock Grid.Column="1" Margin="5,0,0,0" Text="[F2]" Foreground="{StaticResource PopupBackGrand}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"></TextBlock>
                                </Grid>
                            </Border.Child>
                        </Border>
                    </UniformGrid>
                    <TextBlock Text="{Binding Message}" Margin="20, 30" TextWrapping="Wrap"
                       TextAlignment="Center" MaxWidth="100" VerticalAlignment="Center" FontSize="21"/>
                    <PasswordBox  PasswordChar="*" 
                                  extensions:PasswordBoxHelper.Password="{Binding Path=Password,Mode=TwoWay}"  Height="30"
                                  VerticalContentAlignment="Center"
                                  HorizontalAlignment="Stretch"
                                  mah:TextBoxHelper.Watermark="Password"
                                  mah:TextBoxHelper.ClearTextButton="{Binding RelativeSource={RelativeSource Self}, Path=(mah:TextBoxHelper.HasText), Mode=OneWay}"
                                  mah:TextBoxHelper.IsWaitingForData="True"
                                  mah:TextBoxHelper.UseFloatingWatermark="True"
                                  HorizontalContentAlignment="Left"
                                  VerticalAlignment="Center" 
                                  FontSize="15"/>
                </DockPanel>
            </Grid>
        </DockPanel>
    </Border>
</mah:MetroWindow>
