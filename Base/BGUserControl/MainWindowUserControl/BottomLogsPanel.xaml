<UserControl x:Class="BGUserControl.BottomLogsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" >
    <Grid>
        <Border Grid.Row="1" Padding="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#0972C0" Offset="1" />
                    <GradientStop Color="#004F8A" Offset="0.2" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Resources>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="LightGray"></Setter>
                    <Setter Property="BorderThickness" Value="1"></Setter>
                </Style>
            </Border.Resources>
            <Border.Child>
                <Border CornerRadius="5" Padding="0" Background="White">
                    <Border.Child>
                        <ListView Name="lv_Status"  Opacity="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                            HorizontalAlignment="Stretch" ItemContainerStyle="{DynamicResource diyListViewStyle}">
                            <ListView.View>
                                <GridView>
                                    <GridView.Columns>
                                        <GridViewColumn Width="200">
                                            <GridViewColumn.Header>
                                                <Label x:Name="lblTime" Content="{Binding time}" Height="30" Background="#D4EBFD" MinWidth="200" FontSize="{Binding fontSizeModel.normal}" 
                                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
                                            </GridViewColumn.Header>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="gvcLog" Width = "{Binding ListViewHeaderLength}">
                                            <GridViewColumn.Header>
                                                <Label x:Name="lblTitleLog" Background="#D4EBFD" Content="{Binding runLog}" Height="30" MinWidth = "{Binding ListViewHeaderLength}" FontSize="{Binding fontSizeModel.normal}"
                                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="-1,-1,-1,-1"  />
                                            </GridViewColumn.Header>
                                        </GridViewColumn>
                                    </GridView.Columns>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border.Child>
                </Border>
            </Border.Child>
        </Border>
    </Grid>
</UserControl>
