<UserControl x:Class="BGUserControl.CenterStatusControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl" xmlns:bgusercontrol="clr-namespace:BGUserControl;assembly=BGUserControl"
             mc:Ignorable="d" >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="400" />
        </Grid.RowDefinitions>
        <local:EnhanceScanPanel x:Name="EnhanceScanPanel" Grid.Row="0" Grid.RowSpan="4"
                                Panel.ZIndex="999" Height="300" VerticalAlignment="Top"
                                Grid.Column="4" Grid.ColumnSpan="3"/>
        <local:BG_STOP x:Name="StopPanel" Grid.Row="0" Grid.RowSpan="3" Grid.Column="4" Grid.ColumnSpan="3"
                       Width="650" Height="300" HorizontalAlignment="Center" VerticalAlignment="Top"
                       Panel.ZIndex="998" />
        <local:PreviewScanImageCtl Grid.Row="0"  Grid.Column="7" Grid.ColumnSpan="5" VerticalAlignment="Top" HorizontalAlignment="Right" Panel.ZIndex="999"/>
        <local:RayThumbCtl x:Name="RayThumb"  Grid.Column="1" Margin="30,0,0,0"  Grid.ColumnSpan="3" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Top" HorizontalAlignment="Center" Panel.ZIndex="999" Width="300" Height="300"/>
        <local:ScanImage Panel.ZIndex="999" Grid.Column="3" Grid.ColumnSpan="5"  Grid.Row="0" Grid.RowSpan="3" Margin="0,0,0,100"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Visibility="{Binding ScanImageDoubleTipVisibsliy.IsShow}" />
        <local:BSDoseStatusBarCtl x:Name="BSDoseStatusBar" Visibility="Collapsed"  
                                  Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Panel.ZIndex="999" 
                                  Grid.ColumnSpan="3" VerticalAlignment="Top" HorizontalAlignment="Left"
                                  Margin="0,100,10,0"/>

        <local:MainPageImageCtl x:Name="mainPageImage" 
                                Grid.Column="3" Grid.ColumnSpan="5"  Grid.Row="0" Grid.RowSpan="3"  
                                VerticalAlignment="Stretch" HorizontalAlignment="Stretch" 
                                Panel.ZIndex="990" Loaded="mainPageImage_Loaded"/>
        <local:DrawerUploadListViewCtl Grid.Row="2"  Grid.Column="7" Grid.ColumnSpan="5" VerticalAlignment="Stretch" HorizontalAlignment="Right" Panel.ZIndex="999"/>
        <local:OperatorBarCtl Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Left" Grid.Column="1" Grid.ColumnSpan="4"/>
        <local:DoseStatusBarCtl x:Name="DoseStatusBar" Grid.Row="0" Grid.RowSpan="3" Grid.Column="6" Grid.ColumnSpan="6"
                                 VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,100,10,0"/>

        <local:DiyPreviewOrBack x:Name="ScanPreview" Margin="0,0,100,20"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Right" VerticalAlignment="Bottom" Grid.Column="4" 
                                Grid.Row="2"  Foreground="AliceBlue" Visibility="{Binding ScanPreview.IsShow}"/>
        <local:ScanCtl Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Left" Grid.Column="5" Grid.ColumnSpan="4" />

        <local:ElectronicFence  x:Name="ElectronicFence"
            Grid.Column="3" Grid.ColumnSpan="5" Margin="100"
                                     Grid.Row="0" Grid.RowSpan="3"  Panel.ZIndex="997" 
                                        HorizontalAlignment="Stretch" Visibility="{Binding ElectronicFence.IsShow}"
                                        VerticalAlignment="Stretch" Background="Transparent"/>
    </Grid>
</UserControl>
