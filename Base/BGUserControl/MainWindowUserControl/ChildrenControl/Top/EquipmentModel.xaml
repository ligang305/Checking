<UserControl x:Class="BGUserControl.EquipmentModelCtl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="16" d:DesignWidth="800">
    <Grid>
        <Label  HorizontalAlignment="Stretch" FontSize="16px" FontFamily="ArialMT"
                VerticalAlignment="Stretch" FontWeight="DemiBold"
                VerticalContentAlignment="Top" HorizontalContentAlignment="Center" x:Name="lblVersion" 
                Content="{Binding EquipmentModel.LabelText}" Foreground="White" />
    </Grid>
</UserControl>
