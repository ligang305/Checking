<UserControl x:Class="BGUserControl.EquipmentConnectStatusCtl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl" xmlns:bgusercontrol="clr-namespace:BGUserControl;assembly=BGUserControl"
             mc:Ignorable="d" >
    <Grid>
        <StackPanel  Grid.Column="0" Orientation="Vertical" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,0,0">
            <local:DiyStatusLabel x:Name="lbl_PlcConnection" LabelText="{Binding PlcConnection.LabelText}" LabmForecolor="{Binding PlcConnection.LabmForecolor}"  FontSize="{Binding fontSizeModel.normalMiddle}"  HorizontalAlignment="Left" Margin="5,2,0,0"
                               VerticalAlignment="Stretch" VerticalContentAlignment="Center" FontWeight="UltraBold"  HorizontalContentAlignment="Center" Grid.Column="1"/>
            <local:DiyStatusLabel x:Name="lbl_ScanConnection" LabelText="{Binding DetectorConnection.LabelText}"
                                  LabmForecolor="{Binding DetectorConnection.LabmForecolor}" Visibility="{Binding DetectorConnection.IsShow}"
                                  FontSize="{Binding fontSizeModel.normalMiddle}"  HorizontalAlignment="Left" Margin="5,2,0,0"
                               VerticalAlignment="Stretch" VerticalContentAlignment="Center" FontWeight="UltraBold"  HorizontalContentAlignment="Center" Grid.Column="1"/>
            <local:DiyStatusLabel x:Name="lbl_BoostConnection" LabelText="{Binding BoostConnection.LabelText}" LabmForecolor="{Binding BoostConnection.LabmForecolor}"  FontSize="{Binding fontSizeModel.normalMiddle}"  HorizontalAlignment="Left" Margin="5,2,0,0"
                               VerticalAlignment="Stretch" VerticalContentAlignment="Center" FontWeight="UltraBold"  HorizontalContentAlignment="Center" Grid.Column="1"/>
        </StackPanel>
    </Grid>
</UserControl>
