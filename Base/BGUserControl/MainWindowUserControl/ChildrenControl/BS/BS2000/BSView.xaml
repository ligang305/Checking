<UserControl x:Class="BGUserControl.MainWindowUserControl.ChildrenControl.BS.BS2000.BSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" Background="#004E87" BorderBrush="#3A8DB7"
             xmlns:local="clr-namespace:BGUserControl.MainWindowUserControl.ChildrenControl.BS.BS2000" xmlns:bgusercontrol="clr-namespace:BGUserControl"
             mc:Ignorable="d">
         <GroupBox >
            <GroupBox.Header>
              <bgusercontrol:DiyStatusLabel x:Name="lbl_BSDetectorConnection"
                                    LabelText="{Binding DetectorConnectionStatus.LabelText,UpdateSourceTrigger=PropertyChanged}"
                                    LabmForecolor="{Binding DetectorConnectionStatus.LabmForecolor,UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="{Binding fontSizeModel.normalMiddle}"
                                    HorizontalAlignment="Left" Margin="5,2,0,0"
                                    VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                                    FontWeight="UltraBold"  HorizontalContentAlignment="Center" Grid.Row="0"/>
            </GroupBox.Header>
          <Grid HorizontalAlignment="Stretch" x:Name="ImageContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image x:Name="View1" Panel.ZIndex="1000" Source="{Binding BSViewImageSource,Mode=TwoWay}" Stretch="Fill" Grid.Column="1" />

            <!--<bgusercontrol:ImageContent x:Name="MainImage"  Grid.Column="1"/>-->
            <StackPanel x:Name="Operation" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Visibility="{Binding IsTestMode}" >
                <Button Content="{Binding IsConnected,Mode=TwoWay}" 
                        Command="{Binding ConnectionCommand}" Width="80" Height="30"  Margin="5"/>
                <Button Content="扫描" Command="{Binding ScanCommand}"  Width="80" Height="30"  Margin="5"/>
                <Button Content="停止扫描" Command="{Binding DisScanCommand}"  Width="80" Height="30"  Margin="5"/>
                <Button Content="校正" Command="{Binding CorrectCommand}" Width="80" Height="30"  Margin="5"/>
                <Button Content="保存" Command="{Binding SavePngCommand}" Width="80" Height="30"  Margin="5"/>
            </StackPanel>
          </Grid>
        </GroupBox>
</UserControl>
