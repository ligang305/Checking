<UserControl x:Class="BGUserControl.EnhanceScanPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl" 
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls" 
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:command="http://www.galasoft.ch/mvvmlight"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml"/>
    </UserControl.Resources>
    <controls:Flyout x:Name="Flyout" IsModal="True" IsOpen="{Binding IsShowEnhanceScanPanel}" 
                    Position="Top" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                     Background="{StaticResource defaultBlue}" MaxHeight="300">
        <controls:Flyout.Header>
            <Label Content="{Binding EnhanceScan,Mode=TwoWay}" Height="50" 
                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                       VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                       FontSize="20" DockPanel.Dock="Left" Style="{StaticResource diyLabel}"/>
        </controls:Flyout.Header>
        <ListView Grid.Row="1" Grid.Column="0" ItemsSource="{Binding enhanceScanCarInfos,Mode=TwoWay}" 
                      BorderBrush="LightGray" BorderThickness="1" HorizontalContentAlignment="Center"
                      VerticalContentAlignment="Center" 
                   Background="{StaticResource defaultBlue}" >
            <ListView.View>
                <GridView AllowsColumnReorder="False">
                    <GridViewColumn DisplayMemberBinding="{Binding Path=licensePlate}"
                                    Width="149">
                        <GridViewColumn.Header>
                            <Label Width="150"
                                   Content="{Binding licensePlatetxt,Mode=TwoWay}" 
                                   Foreground="White" HorizontalAlignment="Stretch" 
                                   HorizontalContentAlignment="Center" VerticalAlignment="Stretch"
                                   VerticalContentAlignment="Center" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=carLength}" 
                                    Width="149">
                        <GridViewColumn.Header>
                            <Label Width="150"
                                Content="{Binding carLength,Mode=TwoWay}" 
                                Foreground="White" HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Center" VerticalAlignment="Stretch"
                                VerticalContentAlignment="Center" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=StartCarPosition}"
                                     Width="150">
                        <GridViewColumn.Header>
                            <Label Width="150" 
                                Content="{Binding StartCarPosition,Mode=TwoWay}" 
                                Foreground="White" HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Center" VerticalAlignment="Stretch"
                                VerticalContentAlignment="Center" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=EndCarPosition}" 
                                    Width="149">
                        <GridViewColumn.Header>
                            <Label Width="150"
                              Content="{Binding EndCarPosition,Mode=TwoWay}" 
                              Foreground="White" HorizontalAlignment="Stretch" 
                              HorizontalContentAlignment="Center" VerticalAlignment="Stretch"
                              VerticalContentAlignment="Center" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="Control.Background" Value="#00FFFFFF" />
                    <Setter Property="Control.BorderBrush" Value="#FF898989" />
                    <Setter Property="Control.BorderThickness" Value="0" />
                    <Setter Property="Control.Foreground" Value="#FF000000" />
                    <Setter Property="FrameworkElement.Margin" Value="0,0,0,0" />
                    <Setter Property="FrameworkElement.Height" Value="50" />
                    <Setter Property="Control.FontSize" Value="12" />
                    <Setter Property="Control.VerticalContentAlignment" Value="Center" />
                    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Border >
                                    <Border Name="InnerBorder" TextBlock.Foreground="#FF000000"
                                            Background="#00FFFFFF" BorderBrush="#007dc5" BorderThickness="0,1,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="250"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition MaxHeight="50" />
                                            </Grid.RowDefinitions>
                                            <Label Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="#007dc5" Grid.Row="0" Content="{Binding licensePlate,Mode=TwoWay}" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center" />
                                            <Label Grid.Column="1" BorderThickness="0,0,1,0" BorderBrush="#007dc5"  Grid.Row="0" Content="{Binding carLength,Mode=TwoWay}" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center" />
                                            <Label Grid.Column="2" BorderThickness="0,0,1,0" BorderBrush="#007dc5" Grid.Row="0" Content="{Binding StartCarPosition,Mode=TwoWay}"  Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center" />
                                            <Label Grid.Column="3" BorderThickness="0,0,1,0" BorderBrush="#007dc5" Grid.Row="0" Content="{Binding EndCarPosition,Mode=TwoWay}"  Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalAlignment="Stretch" VerticalContentAlignment="Center" />
                                            <StackPanel Orientation="Horizontal" Grid.Column="4" Grid.Row="0" >
                                                <Border Tag="{Binding .}" PreviewMouseLeftButtonDown="Btn_Delete" 
                                                        Style="{DynamicResource diyBtnCarHand}">
                                                    <Label BorderThickness="0,0,0,0" Loaded="Delete_Loaded"
                                                           BorderBrush="#007dc5"
                                                           Style="{DynamicResource diyLabel}" 
                                                           Foreground="White">
                                                    </Label>
                                                </Border>
                                                <Border Tag="{Binding .}"  Style="{DynamicResource diyBtnCarHand}" Margin="20,0,0,0"
                                                        PreviewMouseLeftButtonDown="Btn_Scan">
                                                    <Label BorderThickness="0,0,0,0"   Loaded="Scan_Loaded"
                                                     BorderBrush="#007dc5"
                                                     Style="{DynamicResource diyLabel}" 
                                                     Foreground="White">
                                                    </Label>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </controls:Flyout>
</UserControl>
