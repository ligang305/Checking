<UserControl x:Class="BGUserControl.ElectronicFence"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>
        <local:SingleElectronicFence x:Name="ElectronFenceLeftUp" Grid.Column="0" Grid.Row="0" />
        <local:SingleElectronicFence x:Name="ElectronFenceRightUp" Grid.Column="2" Grid.Row="0" ElectronFenceBattery="{Binding ElectronFenceTwoBattery,Mode=TwoWay}"/>
        <local:SingleElectronicFence x:Name="ElectronFenceLeftDown" Grid.Column="0" Grid.Row="2" ElectronFenceBattery="{Binding ElectronFenceThreeBattery,Mode=TwoWay}"/>
        <local:SingleElectronicFence x:Name="ElectronFenceRightDown" Grid.Column="2" Grid.Row="2" ElectronFenceBattery="{Binding ElectronFenceFourBattery,Mode=TwoWay}"/>
        <Border Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.Column="1" 
                Grid.Row="0" 
                Background="{Binding ElectronFenceUpAlarm,Mode=TwoWay}"  
                Margin="0,0,0,30"/>
        <Border Width="1" HorizontalAlignment="Center"
                VerticalAlignment="Stretch" Grid.Column="0"
                Grid.Row="1" 
                Background="{Binding ElectronFenceUpAlarm,Mode=TwoWay}"  />
        <Border Height="1" HorizontalAlignment="Stretch" 
                VerticalAlignment="Center" Grid.Column="1" Grid.Row="2"
                 Background="{Binding ElectronFenceUpAlarm,Mode=TwoWay}"  
                Margin="0,0,0,30"/>
        <Border Width="1" HorizontalAlignment="Center"
                VerticalAlignment="Stretch" Grid.Column="2" Grid.Row="1"
                 Background="{Binding ElectronFenceUpAlarm,Mode=TwoWay}"  />
    </Grid>
</UserControl>
