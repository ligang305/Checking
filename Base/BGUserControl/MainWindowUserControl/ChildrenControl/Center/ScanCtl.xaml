                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding ScanImageCommand}" CommandParameter="testImg"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Label x:Name="scan217" Content="TestImage" Width="80" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center"   FontSize="{Binding fontSizeModel.normalMiddle}" Foreground="#5BF121" FontWeight="Bold"  />
        </Border>
        <Border x:Name="btnM217Stop" Visibility="{Binding scanVisible.IsShow,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" Style="{DynamicResource diyClycleBorderStyle}"  Grid.Column="1"  HorizontalAlignment="Left" >
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding ScanImageCommand}" CommandParameter="testImgStop"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Label x:Name="scan217Stop" Content="StopImg" Width="80" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center"   FontSize="{Binding fontSizeModel.normalMiddle}" Foreground="#5BF121" FontWeight="Bold"  />
        </Border>-->

        <Border x:Name="btnTest" Visibility="{Binding scanVisible.IsShow,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" Style="{DynamicResource diyClycleBorderStyle}"  Grid.Column="2"  HorizontalAlignment="Left" >
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding ScanImageCommand}" CommandParameter="{Binding scanVisible.Status}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Label x:Name="lblScan" Content="{Binding scanVisible.DisplayName}" Width="80" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center"   FontSize="{Binding fontSizeModel.normalMiddle}" Foreground="#5BF121" FontWeight="Bold"  />
        </Border>

        <Border x:Name="btnStop" Visibility="{Binding stopScanVisible.IsShow,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}"  Style="{DynamicResource diyClycleBorderStyleRed}"  Grid.Column="3"  HorizontalAlignment="Left" >
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDown">
                    <i:InvokeCommandAction Command="{Binding ScanImageCommand}" CommandParameter="{Binding stopScanVisible.Status}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Label x:Name="lblStopScan" Content="{Binding stopScanVisible.DisplayName}" Width="80" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center"  FontSize="{Binding fontSizeModel.normalMiddle}" Foreground="#5BF121" FontWeight="Bold"  />
        </Border>
    </Grid>
</UserControl>
