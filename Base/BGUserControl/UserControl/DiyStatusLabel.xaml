<UserControl x:Class="BGUserControl.DiyStatusLabel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" >
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border x:Name="LambLight" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="20" Height="20"
                CornerRadius="10" BorderBrush="Gray" BorderThickness="2" Grid.Column="0" Grid.Row="0" />
        <Label  Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" Foreground="White" FontFamily="微软雅黑"
               HorizontalContentAlignment="Left" VerticalAlignment="Stretch" VerticalContentAlignment="Center">
            <Label.Content>
                <TextBlock x:Name="lblName" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TextTrimming="CharacterEllipsis" />
            </Label.Content>
        </Label>
    </Grid>
</UserControl>
