<UserControl x:Class="BGUserControl.DiyCacheDelete"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="MainGrid" >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <!--<RowDefinition Height="*"/>-->
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="12*" /> 
            </Grid.ColumnDefinitions>
            <Label x:Name="lblImageCache" Grid.Column="0" Content="{Binding cachePageModel.lblCacheTitle,Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"  Foreground="#1A4F85"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                   Style="{StaticResource diyLabel}" /> <!--Content="{Binding cachePageModel.lblCacheTitle,Mode=TwoWay}"-->
            <Label x:Name="lblImageCacheSize" Grid.Column="1" Grid.ColumnSpan="3" Content="{Binding cachePageModel.lblCacheSize,Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"  Foreground="#1A4F85"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                   Style="{StaticResource diyLabel}"/>
            <Border x:Name="btnClearImageCache"  Grid.Column="4" Style="{StaticResource diyBtnCarHand}" MouseLeftButtonDown="btnClearImageCache_MouseLeftButtonDown" Tag="IMAGE">
                <Label x:Name="lblBtnClearImageCache" HorizontalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                       Content="{Binding cachePageModel.btnCacheTitle,Mode=TwoWay}" Style="{StaticResource diyLabel}" />

            </Border>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="12*" /> 
            </Grid.ColumnDefinitions>
            <Label x:Name="lblLogsCache" Grid.Column="0" Content="{Binding cachePageModel.lblLogCacheTitle,Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Foreground="#1A4F85" Style="{StaticResource diyLabel}" FontSize="{Binding cachePageModel.lblCacheTitleFontsize}" />
            <Label x:Name="lblLogCacheSize" Grid.Column="1" Grid.ColumnSpan="3" Content="{Binding cachePageModel.lblLogscacheSize,Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"  Foreground="#1A4F85"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                   Style="{StaticResource diyLabel}"/>
            <Border x:Name="BtnClearLogsCache"  Grid.Column="4" Style="{StaticResource diyBtnCarHand}" MouseLeftButtonDown="btnClearImageCache_MouseLeftButtonDown" Tag ="LOG">
                <Label x:Name="lblBtnClearLogsCache" HorizontalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                       Content="{Binding cachePageModel.btnLogCacheTitle,Mode=TwoWay}" Style="{StaticResource diyLabel}" />
            </Border>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="12*" />
            </Grid.ColumnDefinitions>
            <Label x:Name="lblImageDataBaseCache" Grid.Column="0" Content="{Binding cachePageModel.lblDataImageCacheTitle,Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Foreground="#1A4F85" Style="{StaticResource diyLabel}"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}" />
            <Label x:Name="lblImageDataBaseCacheSize" Grid.Column="1" Grid.ColumnSpan="3" Content="{Binding cachePageModel.lblDataImagecacheSize,Mode=TwoWay}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"  Foreground="#1A4F85"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                   Style="{StaticResource diyLabel}"/>
            <Border x:Name="BtnImageDataBaseCache"  Grid.Column="4" Style="{StaticResource diyBtnCarHand}" Tag ="DbImage" MouseLeftButtonDown="btnClearImageCache_MouseLeftButtonDown">
                <Label x:Name="lblBtnImageDataBaseCache" HorizontalAlignment="Stretch" Foreground="White" HorizontalContentAlignment="Center"  FontSize="{Binding cachePageModel.lblCacheTitleFontsize}"
                       Content="{Binding cachePageModel.btnDataImageCacheTitle,Mode=TwoWay}" Style="{StaticResource diyLabel}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
