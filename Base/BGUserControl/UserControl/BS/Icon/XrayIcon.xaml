<UserControl x:Class="BGUserControl.XrayIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="35" d:DesignWidth="35">
    <UserControl.Resources>
        <!-- When need to Path graph, please use the ContentControl, and apply this style -->
        <Style x:Key="VectorGraphDrawingImageContentControlStyle" TargetType="{x:Type ContentControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContentControl}">
                        <Viewbox Height="{TemplateBinding Height}" Width="{TemplateBinding Width}">
                            <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}">
                                <Image Source="{TemplateBinding Content}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                            </Border>
                        </Viewbox>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
        <ContentControl Height="35" Width="35" x:Name="BackImage">
            <ContentControl.Content>
            <Border Height="35" Width="35" CornerRadius="15" BorderThickness="0">
                <Image Margin="0,1,0,0">
                    <Image.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup ClipGeometry="M0,0 V40 H40 V0 H0 Z">
                                    <DrawingGroup Opacity="1">
                                        <DrawingGroup Opacity="1">
                                            <GeometryDrawing Brush="{Binding RayBkg,Mode =TwoWay}" Geometry="F1 M40,40z M0,0z M20,39.29C9.36,39.29 0.71,30.64 0.71,20 0.71,9.36 9.36,0.71 20,0.71 30.64,0.71 39.29,9.36 39.29,20 39.29,30.64 30.64,39.29 20,39.29z" />
                                            <DrawingGroup Opacity="1">
                                                <GeometryDrawing Brush="Black" Geometry="F1 M40,40z M0,0z M20,1.42C30.25,1.42 38.58,9.76 38.58,20 38.58,30.24 30.25,38.58 20,38.58 9.75,38.58 1.42,30.25 1.42,20 1.42,9.75 9.75,1.42 20,1.42 M20,0C8.95,0 0,8.95 0,20 0,31.05 8.95,40 20,40 31.05,40 40,31.05 40,20 40,8.95 31.05,0 20,0L20,0z" />
                                            </DrawingGroup>
                                        </DrawingGroup>
                                        <GeometryDrawing Brush="{Binding RayFrg,Mode =TwoWay}">
                                            <GeometryDrawing.Geometry>
                                                <EllipseGeometry RadiusX="3.13" RadiusY="3.13" Center="20,20" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="{Binding RayFrg,Mode =TwoWay}" Geometry="F1 M40,40z M0,0z M28.37,6.8L23.18,14.99C24.84,16.04,25.94,17.89,25.94,20L35.63,20C35.63,14.44,32.73,9.57,28.37,6.8z" />
                                        <GeometryDrawing Brush="{Binding RayFrg,Mode =TwoWay}" Geometry="F1 M40,40z M0,0z M4.38,19.35L14.07,19.75C14.15,17.79,15.2,15.91,17.03,14.85L12.18,6.46C7.37,9.24,4.6,14.19,4.38,19.35z" />
                                        <GeometryDrawing Brush="{Binding RayFrg,Mode =TwoWay}" Geometry="F1 M40,40z M0,0z M27.25,33.85L22.75,25.26C21.01,26.17,18.85,26.2,17.03,25.15L12.18,33.54C16.99,36.32,22.67,36.24,27.25,33.85z" />
                                    </DrawingGroup>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </Image.Source>
                </Image>
            </Border>
            </ContentControl.Content>
        </ContentControl>
</UserControl>
