<local:BaseWindows x:Class="BGUserControl.DiyDetectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BGUserControl"
             mc:Ignorable="d" >
    <Grid x:Name="MainContent" MinWidth="100" MinHeight="150" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border x:Name="lblStatusColor" HorizontalAlignment="Stretch" Margin="5" Grid.Row="0" Grid.Column="0" Background="Green" >
            <Label x:Name="lblStatus" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" 
                    Style="{DynamicResource diyLabel}" FontSize="12" Foreground="White"/>
        </Border>
        <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Label x:Name="lblBoardIndex" Grid.Column="0" Grid.Row="0"  Style="{DynamicResource diyLabel}" FontSize="10" />
            <Label x:Name="lblBoardIndexContent" Grid.Column="1" Grid.Row="0" Style="{DynamicResource diyLabel}" FontSize="10"/>
            <Label x:Name="lblBoardLineIndex" Grid.Column="0" Grid.Row="1"  Style="{DynamicResource diyLabel}" FontSize="10"/>
            <Label x:Name="lblBoardLineIndexContent" Grid.Column="1" Grid.Row="1" Style="{DynamicResource diyLabel}" FontSize="10"/>
        </Grid>
    </Grid>
</local:BaseWindows>
